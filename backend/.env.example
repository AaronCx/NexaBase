# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=NexaBase
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FREE_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ── Usage limits ──────────────────────────────────────────────────────────────
FREE_TIER_MONTHLY_MESSAGES=50
PRO_TIER_MONTHLY_MESSAGES=5000

# ── Error logging ─────────────────────────────────────────────────────────────
# Leave empty to disable external error reporting
ERROR_LOG_ENDPOINT=https://your-error-logger.example.com/errors
ERROR_LOG_API_KEY=your-error-logger-api-key

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
