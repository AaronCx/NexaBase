# Demo mode — set to "true" for a fully navigable demo without Supabase/backend
NEXT_PUBLIC_DEMO_MODE=false

# Supabase (not required when NEXT_PUBLIC_DEMO_MODE=true)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API (not required when NEXT_PUBLIC_DEMO_MODE=true)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe (not required when NEXT_PUBLIC_DEMO_MODE=true)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# App URL (for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (optional — enables live AI chat in demo mode)
# OPENAI_API_KEY=sk-...
